# Banco de Dados
DB_PASSWORD="sua_senha_forte_aqui"
# Se a senha contiver caracteres especiais como @, #, etc., ela precisa ser codificada para a URI
DB_PASSWORD_ENCODED="sua_senha_forte_aqui_codificada_url"
DATABASE_URL="postgresql://postgres:${DB_PASSWORD_ENCODED}@localhost:5432/whatsapp_affiliate?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Configurações da API Backend
PORT=5050
# Gere uma chave aleatória longa e segura (ex: openssl rand -base64 32)
JWT_SECRET="sua_chave_jwt_secreta_aqui"
# Chave compartilhada entre Backend e Worker — gere com openssl rand -base64 32
WORKER_SECRET="sua_chave_worker_secreta_aqui"
# Origem permitida para CORS (URL do seu frontend)
FRONTEND_URL="http://localhost:3000"
WORKER_URL="http://localhost:5001"

# Configurações do Frontend
NEXT_PUBLIC_API_URL="http://localhost:5050"
